PORT=4000
NODE_ENV=production
DB_HOST=mysql
DB_PORT=3306
DB_NAME=roadsafe
DB_USER=roadsafe
DB_PASSWORD=roadsafe_password
SESSION_TTL_HOURS=8
IP_RATE_LIMIT_PER_MIN=300
USER_RATE_LIMIT_PER_MIN=60
TLS_ENABLED=false
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
AES_256_KEY_HEX=PLACEHOLDER_64_HEX_CHARS_FOR_AES_256
INGEST_DROP_ROOT=/var/roadsafe/dropzone
